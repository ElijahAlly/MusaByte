{
  "name": "backend-template",
  "version": "1.0.0",
  "description": "backend template using graphql, mongoose, express, nodejs, and mongodb",
  "main": "index.js",
  "engines": {
    "node": "^10.13.0",
    "npm": "^6.4.1"
  },
  "scripts": {
    "start": "node app.js",
    "server": "nodemon app.js",
    "build": "npm run build --prefix frontend",
    "frontend-install": "npm install --prefix frontend",
    "no-nodemon": "concurrently \"npm run start\" \"npm run frontend\"",
    "frontend": "npm run start --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run frontend\""
  },
  "author": "Elijah Ally",
  "license": "ISC",
  "homepage": "http://ElijahAlly.github.io/MusaByte/frontend",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^6.2.1",
    "express": "^4.17.1",
    "express-graphql": "^0.12.0",
    "graphql": "^15.5.1",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.13.7",
    "passport": "^0.4.1",
    "passport-jwt": "^4.0.0",
    "validator": "^13.6.0",
    "webpack-hot-middleware": "^2.25.0",
    "webpack-plugin-serve": "^1.5.0"
  },
  "devDependencies": {
    "gh-pages": "^3.2.3",
    "nodemon": "^2.0.12"
  }
}
